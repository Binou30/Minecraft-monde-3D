from ursina import *

app = Ursina()

# Sol et bloc
ground = Entity(model='plane', scale=10, collider='box', texture='white_cube', texture_scale=(10,10))
block = Entity(model='cube', color=color.orange, scale=2, position=(0,4,3), collider='box')

# Joueur : cube simple avec collider
player = Entity(model='cube', color=color.azure, scale=(1,2,1), position=(0,1,0), collider='box')

gravity = -20
jump_speed = 7
vertical_velocity = 0
is_grounded = False

def update():
    global vertical_velocity, is_grounded

    # Détecter si joueur est au sol avec un petit rayon vers le bas
    feet_ray = raycast(player.position, Vec3(0,-1,0), distance=1.1, ignore=(player,))
    is_grounded = feet_ray.hit

    # Saut si on est au sol et que espace est pressé
    if is_grounded and held_keys['space']:
        vertical_velocity = jump_speed

    # Appliquer la gravité
    vertical_velocity += gravity * time.dt

    # Détecter collision au plafond (raycast vers le haut)
    head_ray = raycast(player.position + Vec3(0, player.scale_y/2, 0), Vec3(0,1,0), distance=0.1, ignore=(player,))
    if head_ray.hit and vertical_velocity > 0:
        vertical_velocity = 0

    # Déplacer verticalement le joueur
    player.position += Vec3(0, vertical_velocity * time.dt, 0)

    # Correction position sol : si le joueur descend sous le sol, on le remet dessus
    ground_y = 0.5  # comme player a hauteur 2, sol est à y=0 donc limite y=player.scale_y/2=1, j'ai mis 0.5 pour sécurité
    if player.position.y < ground_y:
        player.position = Vec3(player.position.x, ground_y, player.position.z)
        vertical_velocity = 0

app.run()
